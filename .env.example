# Copy to .env and fill in real values. NEVER commit .env to git.
# This file is consumed by:
#   - docker-compose.yml (local dev)
#   - docker-compose.prod.yml (the EC2 host)

# ---------- Database ----------
DB_HOST=db
DB_PORT=5432
DB_NAME=roomie_kz
DB_USER=roomie_user
DB_PASSWORD=change_me_local_only

# ---------- Backend ----------
PORT=5000
# JWT secrets MUST be >= 32 chars. Generate with:
#   openssl rand -hex 48
JWT_SECRET=dev_jwt_secret_change_me_to_a_long_random_string_32chars_min
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_to_a_long_random_string_32chars_min
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
# Comma-separated origins. NEVER use "*" in production.
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://localhost:5173
CLIENT_URL=http://localhost:5174

# ---------- Local-dev port mappings (avoid macOS AirPlay 5000 conflict) ----------
BACKEND_PORT=5050
FRONTEND_PORT=5174

# ---------- Email verification (SMTP / Gmail) ----------
# Leave blank to run the mailer in MOCK mode (codes are printed to the server
# logs instead of being emailed). For real sends with Gmail: enable 2-Step
# Verification, create an App Password, and use it as SMTP_PASS.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# ---------- Production deploy (used by docker-compose.prod.yml on EC2) ----------
APP_PORT=80
BACKEND_IMAGE=yourhandle/roomie-kz-backend
FRONTEND_IMAGE=yourhandle/roomie-kz-frontend
IMAGE_TAG=latest
