# Copy to .env and fill in real values. NEVER commit .env.

# ---- app / compose ----
APP_PORT=3000
DATABASE_URL=postgresql://shanyraq:shanyraq@postgres:5432/shanyraq?schema=public

# ---- postgres container (used by docker-compose) ----
POSTGRES_USER=shanyraq
POSTGRES_PASSWORD=shanyraq
POSTGRES_DB=shanyraq

# ---- deploy (used by docker-compose on EC2) ----
DOCKER_IMAGE=yourhandle/shanyraq-api
IMAGE_TAG=latest
