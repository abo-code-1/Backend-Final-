{
  "name": "roomie-kz-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "node prisma/seed.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules NODE_ENV=test SMTP_HOST= SMTP_USER= SMTP_PASS= jest --runInBand --forceExit",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules NODE_ENV=test SMTP_HOST= SMTP_USER= SMTP_PASS= jest --runInBand tests/emailVerification.unit.test.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
