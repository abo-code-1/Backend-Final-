# Normalize line endings to LF in the repo and on checkout, regardless of a
# contributor's global core.autocrlf setting. (A global core.autocrlf=true on
# macOS was rewriting shebangs to `#!/usr/bin/env node\r`, breaking CLIs.)
* text=auto eol=lf

# Scripts must stay LF so their shebang lines work on macOS/Linux.
*.js   text eol=lf
*.mjs  text eol=lf
*.cjs  text eol=lf
*.ts   text eol=lf
*.sh   text eol=lf

# Treat common binaries as binary so git never touches their bytes.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  text eol=lf
*.woff  binary
*.woff2 binary
